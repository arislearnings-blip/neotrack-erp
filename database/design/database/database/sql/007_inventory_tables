-- ==========================================
-- NeoTrack ERP
-- 007 Inventory Tables
-- ==========================================

CREATE TABLE stock_ledger (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    transaction_date DATE NOT NULL,

    transaction_type VARCHAR(50) NOT NULL,

    reference_type VARCHAR(50),

    reference_id BIGINT,

    warehouse_id BIGINT REFERENCES warehouses(id),

    item_id BIGINT REFERENCES items(id),

    qty_in NUMERIC(18,3) DEFAULT 0,

    qty_out NUMERIC(18,3) DEFAULT 0,

    unit_cost NUMERIC(18,4) DEFAULT 0,

    total_cost NUMERIC(18,2) DEFAULT 0,

    balance_qty NUMERIC(18,3) DEFAULT 0,

    balance_value NUMERIC(18,2) DEFAULT 0,

    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE stock_transfer_header (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    transfer_number VARCHAR(30) UNIQUE NOT NULL,

    transfer_date DATE NOT NULL,

    from_warehouse_id BIGINT REFERENCES warehouses(id),

    to_warehouse_id BIGINT REFERENCES warehouses(id),

    status VARCHAR(30) DEFAULT 'Draft',

    remarks TEXT,

    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE stock_transfer_details (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    transfer_id BIGINT REFERENCES stock_transfer_header(id) ON DELETE CASCADE,

    item_id BIGINT REFERENCES items(id),

    quantity NUMERIC(18,3),

    unit_cost NUMERIC(18,4),

    line_total NUMERIC(18,2)
);

CREATE TABLE stock_adjustment_header (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    adjustment_number VARCHAR(30) UNIQUE NOT NULL,

    adjustment_date DATE NOT NULL,

    warehouse_id BIGINT REFERENCES warehouses(id),

    status VARCHAR(30) DEFAULT 'Draft',

    remarks TEXT,

    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE stock_adjustment_details (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    adjustment_id BIGINT REFERENCES stock_adjustment_header(id) ON DELETE CASCADE,

    item_id BIGINT REFERENCES items(id),

    system_qty NUMERIC(18,3),

    physical_qty NUMERIC(18,3),

    difference_qty NUMERIC(18,3),

    unit_cost NUMERIC(18,4),

    line_total NUMERIC(18,2)
);

CREATE TABLE inventory_count_header (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    count_number VARCHAR(30) UNIQUE NOT NULL,

    count_date DATE NOT NULL,

    warehouse_id BIGINT REFERENCES warehouses(id),

    status VARCHAR(30) DEFAULT 'Draft',

    remarks TEXT,

    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE inventory_count_details (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,

    count_id BIGINT REFERENCES inventory_count_header(id) ON DELETE CASCADE,

    item_id BIGINT REFERENCES items(id),

    system_qty NUMERIC(18,3),

    counted_qty NUMERIC(18,3),

    variance_qty NUMERIC(18,3)
);
